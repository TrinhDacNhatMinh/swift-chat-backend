# App
NODE_ENV=test
PORT=3000

# CORS
CORS_ORIGIN=

# Rate Limit — High limit so E2E tests are never blocked
THROTTLE_TTL=60000
THROTTLE_LIMIT=10000

# PostgreSQL (Prisma)
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=test_database
POSTGRESQL=postgresql://USER:PASSWORD@HOST:5432/test_database?schema=public

# MongoDB (Mongoose)
MONGO_INITDB_ROOT_USERNAME=USER
MONGO_INITDB_ROOT_PASSWORD=PASSWORD
MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/test_database?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true

# JWT
JWT_ACCESS_SECRET=test-access-secret-do-not-use-in-prod
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-prod
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=test-google-client-id

# Cloudinary
CLOUDINARY_CLOUD_NAME=test-cloud-name
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret

# Firebase Cloud Messaging (FCM)
# FIREBASE_PROJECT_ID=test-project-id
# FIREBASE_CLIENT_EMAIL=test@example.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntest\n-----END PRIVATE KEY-----\n"
