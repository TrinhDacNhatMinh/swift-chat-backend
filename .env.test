NODE_ENV=test
PORT=3001

# PostgreSQL (separate test DB)
POSTGRESQL=postgresql://root:rootpassword@localhost:5432/swift_chat_test?schema=public

# MongoDB (separate test DB)
MONGODB_URI=mongodb://root:rootpassword@localhost:27017/swift_chat_test?authSource=admin

# Redis (same instance, different key prefix is fine for test)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (short expiry for tests)
JWT_ACCESS_SECRET=test-access-secret-key
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (not used in e2e tests)
GOOGLE_CLIENT_ID=test-google-client-id

# Cloudinary (not used in e2e tests)
CLOUDINARY_CLOUD_NAME=test
CLOUDINARY_API_KEY=test
CLOUDINARY_API_SECRET=test
